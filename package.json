{
  "name": "@spaceskit/client",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript client SDK for connecting to a Spaceskit Gateway",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:examples": "tsc -p examples/tsconfig.json --noEmit",
    "test:runtime-smoke": "bun run scripts/runtime-smoke.ts",
    "example:basic": "bun run examples/basic-client.ts",
    "example:adapter": "bun run examples/adapter-client.ts",
    "example:workspace": "bun run examples/workspace-client.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "typescript": "^6.0.2"
  }
}
